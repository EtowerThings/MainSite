rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Member-uploaded startup logos: only the signed-in uploader may write their folder; public read for gallery
    match /startup-logos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
